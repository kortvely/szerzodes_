<!DOCTYPE html>
<html lang="hu">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tervezési Szerződés Generátor — MEK 01/2025</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@400;600&family=DM+Sans:wght@400;500;600&display=swap');
:root{--ink:#1c1c1c;--ink2:#444;--ink3:#888;--line:#e5e2db;--paper:#faf9f6;--paper2:#f2f0ea;--green:#2a4a2a;--green2:#3d6b3d;--green3:#f0f5f0;--gold:#9a6f09;--warn:#b83232;}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--paper);color:var(--ink);}
header{background:var(--green);color:white;padding:20px 32px;display:flex;align-items:center;gap:14px;border-bottom:3px solid var(--gold);}
.htxt h1{font-family:'Crimson Pro',serif;font-size:20px;font-weight:600;}
.htxt p{font-size:10px;opacity:.55;margin-top:2px;text-transform:uppercase;letter-spacing:.1em;}
.tabs{background:white;border-bottom:1px solid var(--line);display:flex;overflow-x:auto;padding:0 24px;}
.tab{padding:11px 13px;font-size:10px;font-weight:600;color:var(--ink3);cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;display:flex;align-items:center;gap:5px;text-transform:uppercase;letter-spacing:.06em;transition:all .15s;}
.tab:hover{color:var(--green);}
.tab.active{color:var(--green);border-bottom-color:var(--green);}
.tab.done{color:var(--green2);}
.sn{width:16px;height:16px;border-radius:50%;background:var(--line);display:inline-flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;}
.tab.active .sn{background:var(--green);color:white;}
.tab.done .sn{background:var(--green2);color:white;}
main{max-width:820px;margin:0 auto;padding:28px 28px 80px;}
.panel{display:none;}.panel.active{display:block;}
.pt{font-family:'Crimson Pro',serif;font-size:23px;font-weight:600;margin-bottom:3px;}
.pd{font-size:12px;color:var(--ink3);margin-bottom:20px;line-height:1.6;}
.card{background:white;border:1px solid var(--line);border-radius:10px;padding:20px 24px;margin-bottom:12px;}
.ct{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--green);margin-bottom:14px;padding-bottom:7px;border-bottom:1px solid var(--line);}
.fg{display:grid;grid-template-columns:1fr 1fr;gap:11px 16px;}
.fg1{display:grid;grid-template-columns:1fr;gap:11px;}
.fg3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:11px 16px;}
.fw{grid-column:1/-1;}
.f{display:flex;flex-direction:column;gap:3px;}
label{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--ink2);}
.r{color:var(--warn);margin-left:2px;}
.h{font-weight:400;text-transform:none;letter-spacing:0;color:var(--ink3);margin-left:2px;}
input,textarea{font-family:'DM Sans',sans-serif;font-size:13px;color:var(--ink);background:var(--paper);border:1px solid var(--line);border-radius:8px;padding:7px 10px;width:100%;outline:none;transition:border-color .15s,background .15s;}
input:focus,textarea:focus{border-color:var(--green2);background:white;}
input::placeholder,textarea::placeholder{color:var(--ink3);}
textarea{resize:vertical;min-height:64px;}
.ckg{display:grid;grid-template-columns:1fr 1fr;gap:5px 16px;}
.cki{display:flex;align-items:flex-start;gap:7px;padding:6px 8px;border:1px solid var(--line);border-radius:7px;cursor:pointer;transition:all .15s;}
.cki:hover{border-color:var(--green2);background:var(--green3);}
.cki input[type=checkbox]{width:13px;height:13px;min-width:13px;margin-top:3px;accent-color:var(--green);cursor:pointer;}
.cki .cl{font-size:11.5px;line-height:1.4;}
.vm{font-size:10px;color:var(--warn);margin-top:2px;display:none;}
.f.inv input,.f.inv textarea{border-color:var(--warn);}
.f.inv .vm{display:block;}
.brow{display:flex;align-items:center;gap:9px;margin-top:22px;}
.btn{font-family:'DM Sans',sans-serif;font-size:11px;font-weight:600;letter-spacing:.04em;padding:8px 18px;border-radius:8px;border:none;cursor:pointer;transition:all .15s;display:inline-flex;align-items:center;gap:5px;text-transform:uppercase;}
.bp{background:var(--green);color:white;}
.bp:hover{background:#1c3a1c;}
.bs{background:transparent;color:var(--ink2);border:1px solid var(--line);}
.bs:hover{background:var(--paper2);}
.bg{background:var(--gold);color:white;font-size:13px;padding:10px 22px;}
.bg:hover{background:#7a5607;}
#co{background:white;border:1px solid var(--line);border-radius:10px;overflow:hidden;margin-bottom:16px;}
.ctb{background:var(--paper2);border-bottom:1px solid var(--line);padding:8px 16px;display:flex;align-items:center;justify-content:space-between;}
.ctb span{font-size:9px;color:var(--ink3);font-weight:700;text-transform:uppercase;letter-spacing:.08em;}
#ct{font-family:'Crimson Pro',serif;font-size:13px;line-height:1.85;color:var(--ink);padding:40px 48px;white-space:pre-wrap;max-height:600px;overflow-y:auto;}
#toast{position:fixed;bottom:20px;right:20px;background:var(--green);color:white;padding:9px 15px;border-radius:8px;font-size:11px;font-weight:600;opacity:0;transform:translateY(8px);transition:all .25s;z-index:999;pointer-events:none;}
#toast.show{opacity:1;transform:translateY(0);}
@media(max-width:580px){main{padding:14px;}.fg,.fg3,.ckg{grid-template-columns:1fr;}#ct{padding:20px 16px;font-size:12px;}}
</style>
</head>
<body>
<header>
  <div style="font-size:28px">⚖️</div>
  <div class="htxt"><h1>Tervezési Szerződés Generátor</h1><p>MEK 01/2025 — Teljes tervezői szolgáltatásra</p></div>
</header>
<div class="tabs">
  <div class="tab active" onclick="go(0)"><span class="sn">1</span>Megrendelő</div>
  <div class="tab" onclick="go(1)"><span class="sn">2</span>Tervező</div>
  <div class="tab" onclick="go(2)"><span class="sn">3</span>Projekt</div>
  <div class="tab" onclick="go(3)"><span class="sn">4</span>Szolgáltatások</div>
  <div class="tab" onclick="go(4)"><span class="sn">5</span>Határidők</div>
  <div class="tab" onclick="go(5)"><span class="sn">6</span>Díjazás</div>
  <div class="tab" onclick="go(6)"><span class="sn">7</span>Kapcsolattartó</div>
  <div class="tab" onclick="go(7)"><span class="sn">8</span>Szerződés</div>
</div>
<main>

<div class="panel active" id="p0">
<p class="pt">Megrendelő adatai</p><p class="pd">A szerződést megrendelő fél azonosítási adatai.</p>
<div class="card"><div class="ct">Megrendelő</div>
<div class="fg">
<div class="f fw" id="f-mn"><label>Megrendelő neve<span class="r">*</span></label><input id="mn" placeholder="Pl. Kovács Építész Kft." oninput="sv()"><span class="vm">Kötelező mező.</span></div>
<div class="f fw" id="f-mc"><label>Székhely / lakhely<span class="r">*</span></label><input id="mc" placeholder="1234 Budapest, Példa utca 5." oninput="sv()"><span class="vm">Kötelező mező.</span></div>
<div class="f" id="f-mcj"><label>Cégjegyzékszám</label><input id="mcj" placeholder="01-09-123456" oninput="sv()"></div>
<div class="f" id="f-ma"><label>Adószám<span class="r">*</span></label><input id="ma" placeholder="12345678-1-41" oninput="sv()"><span class="vm">Kötelező.</span></div>
<div class="f fw" id="f-mk"><label>Képviseletében eljár<span class="r">*</span></label><input id="mk" placeholder="Pl. Kovács János, ügyvezető" oninput="sv()"><span class="vm">Kötelező.</span></div>
</div></div>
<div class="brow"><button class="btn bp" onclick="ns(0,['mn','mc','ma','mk'])">Következő →</button></div>
</div>

<div class="panel" id="p1">
<p class="pt">Tervező adatai</p><p class="pd">A tervezői szolgáltatást nyújtó fél adatai.</p>
<div class="card"><div class="ct">Tervező</div>
<div class="fg">
<div class="f fw" id="f-tn"><label>Tervező neve<span class="r">*</span></label><input id="tn" placeholder="Architektúra Stúdió Kft." oninput="sv()"><span class="vm">Kötelező.</span></div>
<div class="f fw" id="f-tc"><label>Székhely / lakhely<span class="r">*</span></label><input id="tc" placeholder="5678 Budapest, Tervező utca 12." oninput="sv()"><span class="vm">Kötelező.</span></div>
<div class="f" id="f-tcj"><label>Cégjegyzékszám</label><input id="tcj" placeholder="01-09-654321" oninput="sv()"></div>
<div class="f" id="f-ta"><label>Adószám<span class="r">*</span></label><input id="ta" placeholder="87654321-2-42" oninput="sv()"><span class="vm">Kötelező.</span></div>
<div class="f"><label>Kamarai cég nyilvántartási szám</label><input id="tkc" placeholder="MÉK-123456" oninput="sv()"></div>
<div class="f"><label>Kamarai névjegyzék szám</label><input id="tkn" placeholder="MÉ-789" oninput="sv()"></div>
<div class="f fw" id="f-tk"><label>Képviseletében eljár<span class="r">*</span></label><input id="tk" placeholder="Kiss Mária, vezető tervező" oninput="sv()"><span class="vm">Kötelező.</span></div>
</div></div>
<div class="brow"><button class="btn bs" onclick="go(0)">← Vissza</button><button class="btn bp" onclick="ns(1,['tn','tc','ta','tk'])">Következő →</button></div>
</div>

<div class="panel" id="p2">
<p class="pt">Projekt adatai</p><p class="pd">Szerződés tárgya, helyszín, ingatlan azonosítói.</p>
<div class="card"><div class="ct">Szerződés tárgya</div>
<div class="fg1">
<div class="f" id="f-st"><label>Szerződés tárgya<span class="r">*</span></label><input id="st" placeholder="Pl. Lakóépület tervezése — engedélyezési + kiviteli terv" oninput="sv()"><span class="vm">Kötelező.</span></div>
<div class="f" id="f-sh"><label>Helyszín<span class="r">*</span></label><input id="sh" placeholder="1234 Budapest, Minta utca 10." oninput="sv()"><span class="vm">Kötelező.</span></div>
<div class="f"><label>Leírás<span class="h">(opcionális)</span></label><textarea id="sl" placeholder="Pl. Kétszintes ikerház, 800 m² telek, 320 m² szintterület" oninput="sv()"></textarea></div>
</div></div>
<div class="card"><div class="ct">Ingatlan azonosítói — 1.1. pont</div>
<div class="fg">
<div class="f" id="f-it"><label>Település<span class="r">*</span></label><input id="it" placeholder="Budapest" oninput="sv()"><span class="vm">Kötelező.</span></div>
<div class="f" id="f-iu"><label>Utca, házszám<span class="r">*</span></label><input id="iu" placeholder="Minta utca 10." oninput="sv()"><span class="vm">Kötelező.</span></div>
<div class="f" id="f-ih"><label>Helyrajzi szám (HRSZ)<span class="r">*</span></label><input id="ih" placeholder="12345/6" oninput="sv()"><span class="vm">Kötelező.</span></div>
<div class="f" id="f-im"><label>Ingatlan megnevezése<span class="r">*</span></label><input id="im" placeholder="kivett lakóház, udvar és kert" oninput="sv()"><span class="vm">Kötelező.</span></div>
<div class="f fw" id="f-ie"><label>Építmény megnevezése<span class="r">*</span></label><input id="ie" placeholder="2 lakásos ikerház" oninput="sv()"><span class="vm">Kötelező.</span></div>
</div></div>
<div class="brow"><button class="btn bs" onclick="go(1)">← Vissza</button><button class="btn bp" onclick="ns(2,['st','sh','it','iu','ih','im','ie'])">Következő →</button></div>
</div>

<div class="panel" id="p3">
<p class="pt">Tervezői szolgáltatások</p><p class="pd">A nem jelölt pontok törlésre kerülnek a szerződésből (2.2. pont).</p>
<div class="card"><div class="ct">Alapszolgáltatások — 2.2. pont</div>
<div class="ckg">
<label class="cki"><input type="checkbox" id="sa" onchange="sv()"><span class="cl">a) Tervezési program</span></label>
<label class="cki"><input type="checkbox" id="sb" onchange="sv()"><span class="cl">b) Megvalósíthatósági tanulmány</span></label>
<label class="cki"><input type="checkbox" id="sc" checked onchange="sv()"><span class="cl">c) Tanulmányterv / Vázlatterv / Koncepcióterv</span></label>
<label class="cki"><input type="checkbox" id="sd" onchange="sv()"><span class="cl">d) Jóváhagyási terv (nem engedélyköteles)</span></label>
<label class="cki"><input type="checkbox" id="se" checked onchange="sv()"><span class="cl">e) Építési engedélyezési / egyszerű bejelentési terv</span></label>
<label class="cki"><input type="checkbox" id="sf" checked onchange="sv()"><span class="cl">f) Kivitelezési terv</span></label>
<label class="cki"><input type="checkbox" id="sg" onchange="sv()"><span class="cl">g) Megvalósulási terv</span></label>
<label class="cki"><input type="checkbox" id="sh2" onchange="sv()"><span class="cl">h) Kezelési / karbantartási terv</span></label>
<label class="cki"><input type="checkbox" id="si" onchange="sv()"><span class="cl">i) Jóváhagyási terv (állami beruházás)</span></label>
<label class="cki"><input type="checkbox" id="sj" checked onchange="sv()"><span class="cl">j) Tervezői művezetés</span></label>
</div></div>
<div class="card"><div class="ct">Opcionálisan kitölthető pontok</div>
<div class="fg1">
<div class="f"><label>2.4. Megvalósíthatósági tanulmány tartalma</label><textarea id="mt" placeholder="Nem releváns / tartalmi leírás" rows="2" oninput="sv()"></textarea></div>
<div class="f"><label>2.5. Tanulmányterv formai és tartalmi követelmények</label><textarea id="tt" placeholder="Pl. 1:100 méretarány, 2 nyomtatott + 1 digitális példány" rows="2" oninput="sv()"></textarea></div>
<div class="f"><label>2.10. Kezelési és karbantartási terv tartalma</label><textarea id="kt" placeholder="Pl. nem szükséges / részletes leírás" rows="2" oninput="sv()"></textarea></div>
<div class="f"><label>2.12. Nem alapszolgáltatás — egyéb sor</label><input id="nem12" placeholder="Pl. Belsőépítészeti terv" oninput="sv()"></div>
<div class="f"><label>3.2. Különszolgáltatások felsorolása</label><textarea id="ks" placeholder="– Meglévő épület felmérése&#10;– Épületenergetikai tanúsítvány" rows="3" oninput="sv()"></textarea></div>
</div></div>
<div class="brow"><button class="btn bs" onclick="go(2)">← Vissza</button><button class="btn bp" onclick="ns(3,[])">Következő →</button></div>
</div>

<div class="panel" id="p4">
<p class="pt">Teljesítési határidők</p><p class="pd">4. és 5. pont — adatszolgáltatás és tervszállítás határideje.</p>
<div class="card"><div class="ct">Megrendelői adatszolgáltatás — 4. pont</div>
<div class="fg3">
<div class="f"><label>Geodéziai felmérés<span class="h">(nap)</span></label><input type="number" id="hg" placeholder="15" min="1" oninput="sv()"></div>
<div class="f"><label>Geotechnikai vizsgálat<span class="h">(nap)</span></label><input type="number" id="hgt" placeholder="30" min="1" oninput="sv()"></div>
<div class="f"><label>4.5. sor megnevezése</label><input id="h45n" placeholder="Pl. Felmérési rajz" oninput="sv()"></div>
<div class="f"><label>4.5. határidő<span class="h">(nap)</span></label><input type="number" id="h45" placeholder="20" min="1" oninput="sv()"></div>
</div></div>
<div class="card"><div class="ct">Tervszállítási részteljesítések — 5.1. pont</div>
<div class="fg1">
<div class="f"><label>Részteljesítési határidők<span class="r">*</span></label><textarea id="rt" placeholder="1. Koncepcióterv: 30. nap&#10;2. Engedélyezési terv: 90. nap&#10;3. Kivitelezési terv: 150. nap" rows="4" oninput="sv()"></textarea></div>
<div class="f"><label>Kifogások javítási határideje — 5.3. pont<span class="h">(munkanap)</span></label><input type="number" id="kh" placeholder="5" min="1" oninput="sv()"></div>
<div class="f"><label>Megrendelő állásfoglalási határideje — 8.1. pont<span class="h">(naptári nap)</span></label><input type="number" id="ah" placeholder="5" min="1" oninput="sv()"></div>
</div></div>
<div class="brow"><button class="btn bs" onclick="go(3)">← Vissza</button><button class="btn bp" onclick="ns(4,[])">Következő →</button></div>
</div>

<div class="panel" id="p5">
<p class="pt">Tervezési díj és fizetési feltételek</p><p class="pd">6. pont — díj, fizetési ütemezés, bankszámla; 2.11.2. — művezetési óradíj; 9.5. — kötbér.</p>
<div class="card"><div class="ct">Tervezési és felhasználási díj — 6.1. pont</div>
<div class="fg">
<div class="f" id="f-ds"><label>Tervezési díj — számmal (Ft+ÁFA)<span class="r">*</span></label><input id="ds" placeholder="2 500 000" oninput="sv()"><span class="vm">Kötelező.</span></div>
<div class="f" id="f-db"><label>Tervezési díj — betűvel<span class="r">*</span></label><input id="db" placeholder="kétmillió-ötszázezer" oninput="sv()"><span class="vm">Kötelező.</span></div>
<div class="f"><label>Felhasználási díj aránya<span class="h">(%)</span></label><input type="number" id="fd" placeholder="20" min="0" max="100" oninput="sv()"></div>
<div class="f"><label>Fizetési ütemezés — 6.2. pont</label><textarea id="fu" placeholder="30% szerződéskötéskor, 50% engedélyezési terv átadásakor, 20% kiviteli terv átadásakor" rows="3" oninput="sv()"></textarea></div>
<div class="f fw" id="f-bs2"><label>Tervező bankszámlaszáma — 6.3. pont<span class="r">*</span></label><input id="bs2" placeholder="12345678-12345678-12345678" oninput="sv()"><span class="vm">Kötelező.</span></div>
</div></div>
<div class="card"><div class="ct">Művezetési óradíj — 2.11.2. pont</div>
<div class="fg">
<div class="f"><label>Óradíj — számmal (Ft+ÁFA)</label><input id="os" placeholder="25 000" oninput="sv()"></div>
<div class="f"><label>Óradíj — betűvel</label><input id="ob" placeholder="huszonötezer" oninput="sv()"></div>
</div></div>
<div class="card"><div class="ct">Késedelmi kötbér — 9.5. pont</div>
<div class="fg">
<div class="f"><label>Kötbér mértéke<span class="h">(%/nap)</span></label><input type="number" id="ko" placeholder="0.5" step="0.1" min="0" max="5" oninput="sv()"></div>
</div></div>
<div class="brow"><button class="btn bs" onclick="go(4)">← Vissza</button><button class="btn bp" onclick="ns(5,['ds','db','bs2'])">Következő →</button></div>
</div>

<div class="panel" id="p6">
<p class="pt">Kapcsolattartók — 11. pont</p><p class="pd">Képviselők neve, beosztása, levelezési elérhetőségek.</p>
<div class="card"><div class="ct">Megrendelő részéről</div>
<div class="fg">
<div class="f fw"><label>Kapcsolattartó neve, beosztása</label><input id="mkn" placeholder="Kovács János, ügyvezető" oninput="sv()"></div>
<div class="f fw"><label>Levelezési cím</label><input id="mkl" placeholder="1234 Budapest, Minta utca 5." oninput="sv()"></div>
<div class="f"><label>E-mail cím</label><input type="email" id="mke" placeholder="kovacs@pelda.hu" oninput="sv()"></div>
<div class="f"><label>Telefon</label><input type="tel" id="mkt" placeholder="+36 30 123 4567" oninput="sv()"></div>
</div></div>
<div class="card"><div class="ct">Tervező részéről</div>
<div class="fg">
<div class="f fw"><label>Kapcsolattartó neve, beosztása</label><input id="tkn2" placeholder="Kiss Mária, vezető tervező" oninput="sv()"></div>
<div class="f fw"><label>Levelezési cím</label><input id="tkl" placeholder="5678 Budapest, Tervező utca 12." oninput="sv()"></div>
<div class="f"><label>E-mail cím</label><input type="email" id="tke" placeholder="kiss@studio.hu" oninput="sv()"></div>
<div class="f"><label>Telefon</label><input type="tel" id="tkt" placeholder="+36 1 234 5678" oninput="sv()"></div>
</div></div>
<div class="card"><div class="ct">Mellékletek</div>
<div class="fg1"><div class="f"><label>2. sz. melléklet megnevezése</label><input id="mel2" placeholder="Pl. Díjfizetési ütemterv" oninput="sv()"></div></div>
</div>
<div class="brow"><button class="btn bs" onclick="go(5)">← Vissza</button><button class="btn bp" onclick="gen()">Szerződés generálása →</button></div>
</div>

<div class="panel" id="p7">
<p class="pt">Kész szerződés</p><p class="pd">A teljes kitöltött szerződés szövege. Másolja ki vagy töltse le .txt fájlként.</p>
<div id="co">
<div class="ctb"><span>MEK 01/2025 — Kitöltött változat</span><button class="btn bp" onclick="cp()" style="font-size:10px;padding:5px 12px;">📋 Másolás</button></div>
<div id="ct">A szerződés itt jelenik meg...</div>
</div>
<div class="brow">
<button class="btn bs" onclick="go(6)">← Vissza / Szerkesztés</button>
<button class="btn bg" onclick="dl()">⬇ Letöltés .txt</button>
</div>
</div>

</main>
